{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@checkout/*": ["src/checkout/*"],
      "@rest/*": ["src/rest/*"],
      "@common/*": ["src/common/*"],
      "@types/*": ["src/types/*"],
      "@utils/*": ["src/utils/*"],
      "@test/*": ["test/*"]
    }
  },
  "include": ["src", "test", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
